!.cursor/rules/*.mdc
!raw/
raw/*
!raw/articles/
raw/articles/*
!raw/articles/.gitkeep
!raw/assets/
raw/assets/*
!raw/assets/.gitkeep
!schemas/
schemas/*
!schemas/wiki-schema.md
!schemas/workflows.md
!wiki/
wiki/*
!wiki/README.md
!wiki/index.template.md
!wiki/source-notes/
wiki/source-notes/*
!wiki/source-notes/_template.md
!wiki/entities/
wiki/entities/*
!wiki/entities/_template.md
!wiki/concepts/
wiki/concepts/*
!wiki/concepts/_template.md
!wiki/synthesis/
wiki/synthesis/*
